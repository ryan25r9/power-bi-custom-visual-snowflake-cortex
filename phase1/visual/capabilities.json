{
  "dataRoles": [
    {
      "displayName": "Context fields",
      "name": "contextFields",
      "kind": "GroupingOrMeasure",
      "description": "Dimensions and measures that define this page's story. Arrives already filtered by every active slicer/filter — this is what the agent 'sees'. A visual can only read fields bound here, so bind the Region/Year/etc. you want the agent aware of."
    },
    {
      "displayName": "Answer text",
      "name": "answerText",
      "kind": "Grouping",
      "description": "Bind the ANSWER_TEXT column returned by the Cortex answer query. The agent's reply lands here as a row of data after you ask a question."
    },
    {
      "displayName": "Prompt binding field",
      "name": "promptField",
      "kind": "Grouping",
      "description": "Bind PromptBinding[Prompt] here on a second, input-only instance (nothing else bound). A visual's applied filter has slicer semantics — it filters every OTHER visual, never its own query — so the instance that sends the question must be separate from the one that displays the answer."
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        { "promptField": { "min": 1, "max": 1 }, "contextFields": { "max": 0 }, "answerText": { "max": 0 } }
      ],
      "categorical": {
        "categories": {
          "for": { "in": "promptField" },
          "dataReductionAlgorithm": { "top": { "count": 100 } }
        }
      }
    },
    {
      "conditions": [
        { "promptField": { "min": 1, "max": 1 }, "answerText": { "min": 1 } }
      ],
      "table": {
        "rows": {
          "select": [
            { "for": { "in": "contextFields" } },
            { "for": { "in": "answerText" } }
          ],
          "dataReductionAlgorithm": { "top": { "count": 1000 } }
        }
      }
    },
    {
      "conditions": [
        { "promptField": { "max": 0 } }
      ],
      "table": {
        "rows": {
          "select": [
            { "for": { "in": "contextFields" } },
            { "for": { "in": "answerText" } }
          ],
          "dataReductionAlgorithm": { "top": { "count": 1000 } }
        }
      }
    }
  ],
  "objects": {
    "agent": {
      "properties": {
        "bindingTable": { "type": { "text": true } },
        "bindingColumn": { "type": { "text": true } },
        "includeContext": { "type": { "bool": true } },
        "maxContextRows": { "type": { "numeric": true } },
        "agentHint": { "type": { "text": true } },
        "answerTimeoutSecs": { "type": { "numeric": true } },
        "forceInputMode": { "type": { "bool": true } },
        "plainTextHint": { "type": { "bool": true } },
        "filterShape": {
          "type": {
            "enumeration": [
              { "displayName": "Advanced 'Is' (pane-proven)", "value": "advanced" },
              { "displayName": "Basic 'In' (slicer-canonical)", "value": "basic" },
              { "displayName": "Identity (ChicletSlicer-style; question must match a suggestion)", "value": "identity" }
            ]
          }
        }
      }
    },
    "general": {
      "properties": {
        "filter": { "type": { "filter": true } },
        "selfFilter": { "type": { "filter": { "selfFilter": true } } }
      }
    }
  },
  "privileges": [],
  "supportsEmptyDataView": true,
  "supportsLandingPage": true,
  "suppressDefaultTitle": true
}
